        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AjikApps">
        <activity
            android:name=".pertemuan5.SplashScreenActivity"
            android:exported="false" />
        <activity
            android:name=".AuthActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- WEBVIEW -->
        <activity
            android:name=".pertemuan_5.WebViewActivity"
            android:exported="false" /> <!-- PERTEMUAN 4 -->
        <activity
            android:name=".pertemuan4.FourthActivity"
            android:exported="false" /> <!-- PERTEMUAN 3 -->
        <activity
            android:name=".pertemuan3.ThirdResaultActivity"
            android:exported="false" />
        <activity
            android:name=".pertemuan3.ThirdActivity"
            android:exported="false" /> <!-- PERTEMUAN 2 -->
        <activity
            android:name=".pertemuan2.SecondActivity"
            android:exported="false" /> <!-- MAIN lama (opsional, tetap boleh ada) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
    </application>

</manifest>