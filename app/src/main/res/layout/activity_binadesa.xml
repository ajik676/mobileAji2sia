<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="45dp"
        android:elevation="4dp"
        app:srcCompat="@drawable/logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bina Desa"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sistem Informasi Homestay"
                android:textSize="14sp"
                android:textColor="#546E7A"
                android:layout_marginBottom="32dp"/>

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="#1E88E5"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Layanan"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#1F2A44"
                android:layout_marginBottom="20dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWebsite"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Akses Website Desa"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                app:icon="@android:drawable/ic_menu_search"
                app:iconGravity="textStart"
                app:cornerRadius="18dp"
                android:layout_marginBottom="12dp"
                android:elevation="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Keluar Sistem"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#D32F2F"
                app:strokeColor="#D32F2F"
                app:strokeWidth="2dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="#D32F2F"
                app:iconGravity="textStart"
                app:cornerRadius="18dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pengelolaan Desa Wisata Digital © 2026"
        android:textColor="#90A4AE"
        android:textSize="11sp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>