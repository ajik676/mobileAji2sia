<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9F6"> <View
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="@drawable/bg_profile_header" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Profil Saya"
            app:titleCentered="true"
            app:titleTextColor="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:gravity="center_horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="130dp"
                android:layout_height="130dp"
                app:cardCornerRadius="65dp"
                app:cardElevation="8dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="4dp"
                android:layout_marginTop="50dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logoaji" /> </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MUHAMMAD HIRZI KURNIAWAN"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:textAlignment="center"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kelas 2 SIA"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeWidth="0dp"
                app:rippleColor="#C8E6C9"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Kontak &amp; Sosial Media"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#78909C"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:textAllCaps="true"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="hirzi.kurniawan@email.com"
                        android:textColor="#455A64"
                        android:textSize="15sp"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:drawableStart="@android:drawable/ic_dialog_email"
                        android:drawableTint="#2E7D32"
                        android:drawablePadding="20dp"
                        android:gravity="center_vertical"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginStart="64dp"/>

                    <TextView
                        android:id="@+id/tvLinkedIn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="linkedin.com/in/mhirzikurniawan"
                        android:textColor="#455A64"
                        android:textSize="15sp"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:drawableStart="@android:drawable/ic_menu_share"
                        android:drawableTint="#0077B5"
                        android:drawablePadding="20dp"
                        android:gravity="center_vertical"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginStart="64dp"/>

                    <TextView
                        android:id="@+id/tvGithub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="github.com/mhirzikurniawan"
                        android:textColor="#455A64"
                        android:textSize="15sp"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:drawableStart="@android:drawable/ic_menu_manage"
                        android:drawableTint="#333333"
                        android:drawablePadding="20dp"
                        android:gravity="center_vertical"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginStart="64dp"/>

                    <TextView
                        android:id="@+id/tvInstagram"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="mhirzi.kurniawan"
                        android:textColor="#455A64"
                        android:textSize="15sp"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:drawableStart="@android:drawable/ic_menu_camera"
                        android:drawableTint="#E1306C"
                        android:drawablePadding="20dp"
                        android:gravity="center_vertical"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>