<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F6"> <com.google.android.material.appbar.AppBarLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@android:color/white"
    app:elevation="2dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="Profil Saya"
        app:titleCentered="true"
        app:titleTextColor="#212121"
        app:layout_scrollFlags="scroll|enterAlways" />
</com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="6dp"
                app:strokeColor="#2E7D32"
                app:strokeWidth="2dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MUHAMMAD HIRZI KURNIAWAN"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:textAlignment="center"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="8dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelas 2 SIA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Informasi Kontak &amp; Tautan"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#757575"
                        android:padding="16dp"
                        android:background="#FAFAFA"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="hirzi.kurniawan@email.com"
                        android:textColor="#424242"
                        android:textSize="15sp"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:drawableStart="@android:drawable/ic_dialog_email"
                        android:drawableTint="#2E7D32"
                        android:drawablePadding="16dp"
                        android:gravity="center_vertical"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginStart="48dp"/>

                    <TextView
                        android:id="@+id/tvLinkedIn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="linkedin.com/in/mhirzikurniawan"
                        android:textColor="#424242"
                        android:textSize="15sp"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:drawableStart="@android:drawable/ic_menu_share"
                        android:drawableTint="#0077B5" android:drawablePadding="16dp"
                        android:gravity="center_vertical"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginStart="48dp"/>

                    <TextView
                        android:id="@+id/tvGithub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="github.com/mhirzikurniawan"
                        android:textColor="#424242"
                        android:textSize="15sp"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:drawableStart="@android:drawable/ic_menu_manage"
                        android:drawableTint="#333333" android:drawablePadding="16dp"
                        android:gravity="center_vertical"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginStart="48dp"/>

                    <TextView
                        android:id="@+id/tvInstagram"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="mhirzi.kurniawan"
                        android:textColor="#424242"
                        android:textSize="15sp"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:drawableStart="@android:drawable/ic_menu_camera"
                        android:drawableTint="#E1306C" android:drawablePadding="16dp"
                        android:gravity="center_vertical"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>