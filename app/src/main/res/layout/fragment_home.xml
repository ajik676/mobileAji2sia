<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Belajar Mobile itu Asyiik!"
        android:textColor="#4A4A4A"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan2"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Pertemuan 2"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            android:backgroundTint="#6750A4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan3"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Pertemuan 3"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            android:backgroundTint="#6750A4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan4"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Pertemuan 4"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            android:backgroundTint="#6750A4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan5"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Pertemuan 5"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            android:backgroundTint="#6750A4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan7"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Pertemuan 7"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            android:backgroundTint="#6750A4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan9"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:text="Pertemuan 9"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            android:backgroundTint="#6750A4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan10"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="32dp"
            android:text="Pertemuan 10"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            android:backgroundTint="#6750A4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="120dp"
            android:layout_height="55dp"
            android:text="Logout"
            android:textAllCaps="false"
            app:backgroundTint="#FF0000"
            app:cornerRadius="28dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>