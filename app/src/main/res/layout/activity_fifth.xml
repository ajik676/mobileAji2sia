                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kami hadir dengan visi untuk memberikan solusi teknologi terbaik bagi kebutuhan Anda. Aplikasi ini dirancang secara khusus untuk mengedepankan efisiensi, kemudahan penggunaan, dan pengalaman pengguna yang luar biasa dalam setiap interaksi."
                android:textColor="#424242"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Melalui platform ini, Anda dapat mengakses berbagai fitur unggulan yang terintegrasi secara cerdas. Kami terus melakukan pembaruan sistem secara berkala untuk memastikan stabilitas aplikasi dan menghadirkan inovasi terbaru yang relevan dengan perkembangan industri."
                android:textColor="#424242"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Keamanan data dan privasi Anda adalah prioritas utama kami. Seluruh informasi yang diproses di dalam aplikasi telah dilindungi menggunakan teknologi enkripsi standar industri terkini, sehingga Anda dapat bertransaksi dan beraktivitas dengan rasa aman dan tenang."
                android:textColor="#424242"
                android:textSize="15sp"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tim dukungan kami selalu siap membantu Anda kapan pun dibutuhkan. Jangan ragu untuk memanfaatkan fitur pusat bantuan atau menghubungi layanan pelanggan kami apabila Anda memiliki pertanyaan, kendala, atau masukan untuk pengembangan aplikasi ke depannya."
